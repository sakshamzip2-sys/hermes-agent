<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  OpenComputer VNC fast-path tunnel.

  The agent VM's noVNC runs on 127.0.0.1:6080 (loopback only). Reaching it via
  the public Cloudflare tunnel adds latency; forwarding it over Tailscale SSH
  is materially faster (~3.4x in practice) for the in-app Computer preview.
  This holds an `ssh -L 6080:127.0.0.1:6080` tunnel to agent-0ef24345
  (100.124.164.84) so the local app can hit ws://127.0.0.1:6080/websockify
  directly. KeepAlive=true relaunches it on drop/reboot.

  Install:
    cp ai.opencomputer.vnc-tunnel.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/ai.opencomputer.vnc-tunnel.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.opencomputer.vnc-tunnel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/ssh</string>
        <string>-N</string>
        <string>-L</string>
        <string>127.0.0.1:6080:127.0.0.1:6080</string>
        <string>-o</string>
        <string>BatchMode=yes</string>
        <string>-o</string>
        <string>ExitOnForwardFailure=yes</string>
        <string>-o</string>
        <string>StrictHostKeyChecking=accept-new</string>
        <string>-o</string>
        <string>ServerAliveInterval=30</string>
        <string>-o</string>
        <string>ServerAliveCountMax=3</string>
        <string>root@100.124.164.84</string>
    </array>

    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>15</integer>

    <key>StandardOutPath</key>
    <string>/Users/saksham/Library/Logs/opencomputer/vnc-tunnel.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/saksham/Library/Logs/opencomputer/vnc-tunnel.err.log</string>
</dict>
</plist>
